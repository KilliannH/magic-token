# Backend
PORT=3001
NODE_ENV=development

# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/mgc
# Hosted (Railway, Supabase, Neon...): paste your connection URL here
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mgc

# Set to true if your DB requires SSL (most hosted DBs do)
DATABASE_SSL=false

# Solana (optional, for future on-chain integration)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# MGC_TOKEN_MINT=your_token_mint_address

# Tournament
TREASURY_WALLET=your_solana_wallet_for_entry_fees
TOURNAMENT_ENTRY_FEE=1000